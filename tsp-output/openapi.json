          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Фильтр по статусу",
            "schema": {
              "$ref": "#/components/schemas/BookingStatus"
            },
            "explode": false
          },
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "description": "Фильтр по дате начала (включительно)",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "explode": false
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "Фильтр по дате окончания (включительно)",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "explode": false
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Пагинация - номер страницы",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "default": 1
            },
            "explode": false
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "description": "Пагинация - размер страницы",
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "explode": false
          }
        ],
        "responses": {
          "200": {
            "description": "The request has succeeded.",
            "headers": {
              "total-count": {
                "required": true,
                "schema": {
                  "type": "integer",
                  "format": "int32"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Booking"
                  }
                }
              }
            }
          },
          "404": {
            "description": "The server cannot find the requested resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        },
