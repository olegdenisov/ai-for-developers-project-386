  "components": {
    "schemas": {
      "Booking": {
        "type": "object",
        "required": [
          "id",
          "eventTypeId",
          "slotId",
          "guestName",
          "guestEmail",
          "status",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "eventTypeId": {
            "type": "string",
            "description": "Ссылка на тип события"
          },
          "slotId": {
            "type": "string",
            "description": "Ссылка на забронированный слот"
          },
          "guestName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Имя гостя"
          },
          "guestEmail": {
            "type": "string",
            "format": "email",
            "description": "Email гостя"
          },
          "guestNotes": {
            "type": "string",
            "maxLength": 1000,
            "description": "Дополнительные заметки от гостя"
          },
          "status": {
            "allOf": [
              {
                "$ref": "#/components/schemas/BookingStatus"
              }
            ],
            "description": "Статус бронирования"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Автоматически генерируемая метка времени создания"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Автоматически генерируемая метка времени обновления"
          },
          "eventType": {
            "allOf": [
              {
                "$ref": "#/components/schemas/EventType"
              }
            ],
            "description": "Вложенный тип события (включается при получении деталей бронирования)"
          },
          "slot": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Slot"
              }
            ],
            "description": "Вложенный слот (включается при получении деталей бронирования)"
          }
        },
        "description": "Booking - бронирование, создаваемое гостём на выбранный слот.\nСодержит информацию о госте и выбранном типе события."
      },
      "BookingStatus": {
        "type": "string",
        "enum": [
          "confirmed",
          "cancelled",
          "completed"
        ],
        "description": "Статусы бронирования"
      },
      "CancelBookingRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "maxLength": 500,
            "description": "Причина отмены (опционально)"
          }
        },
        "description": "DTO для отмены бронирования (гость)"
      },
      "CreateBookingRequest": {
        "type": "object",
        "required": [
          "eventTypeId",
          "slotId",
          "guestName",
          "guestEmail"
        ],
        "properties": {
          "eventTypeId": {
            "type": "string",
            "format": "uuid"
          },
          "slotId": {
            "type": "string",
            "format": "uuid"
          },
          "guestName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "guestEmail": {
            "type": "string",
            "format": "email"
          },
          "guestNotes": {
            "type": "string",
            "maxLength": 1000
          }
        },
        "description": "DTO для создания бронирования (гость)"
      },
