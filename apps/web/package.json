{
  "name": "@calendar-booking/web",
  "version": "1.0.0",
  "description": "Calendar Booking Web Frontend - React 19 + FSD + Reatom v1000 + Mantine",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host",
    "build": "tsc && vite build",
    "preview": "vite preview --port 5173",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@calendar-booking/api-client": "workspace:*",
    "@calendar-booking/shared-types": "workspace:*",
    "@mantine/core": "^7.14.0",
    "@mantine/dates": "^7.14.0",
    "@mantine/form": "^7.14.0",
    "@mantine/hooks": "^7.14.0",
    "@mantine/modals": "^7.14.0",
    "@reatom/core": "^1000.0.0",
    "@reatom/jsx": "^1000.0.0",
    "@reatom/router": "^1000.0.0",
    "@reatom/async": "^1000.0.0",
    "@reatom/logger": "^1000.0.0",
    "dayjs": "^1.11.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "postcss": "^8.4.49",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
