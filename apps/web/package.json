{
  "name": "@calendar-booking/web",
  "version": "1.0.0",
  "description": "Calendar Booking Web Frontend - React 19 + FSD + Reatom v1000 + Mantine",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host",
    "build": "tsc && vite build",
    "preview": "vite preview --port 5173",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@calendar-booking/api-client": "workspace:*",
    "@calendar-booking/shared-types": "workspace:*",
    "@mantine/core": "9.0.0",
    "@mantine/dates": "9.0.0",
    "@mantine/form": "9.0.0",
    "@mantine/hooks": "9.0.0",
    "@mantine/modals": "9.0.0",
    "@reatom/core": "1000.15.2",
    "@reatom/jsx": "1000.1.0",
    "@reatom/react": "1000.2.2",
    "@reatom/url": "3.9.0",
    "@tabler/icons-react": "3.41.1",
    "dayjs": "1.11.20",
    "mantine-form-zod-resolver": "2.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "postcss": "8.5.8",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "7.0.1",
    "typescript": "6.0.2",
    "vite": "8.0.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
